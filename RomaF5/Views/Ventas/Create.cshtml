@model RomaF5.Models.Venta

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productos = (List<Producto>)ViewBag.Productos;
}

<h4 style="text-align:center">Venta</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="Fecha" class="control-label"></label>
                <input asp-for="Fecha" class="form-control" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Cliente:</label>
                <select asp-for="ClienteId" class="form-control">
                    @foreach (var cliente in ViewBag.Clientes)
                    {
                        <option value="@cliente.Id">@cliente.Nombre</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Productos:</label>
                <input type="text" id="searchInput" class="form-control" placeholder="Buscar producto..." autocomplete="off" />
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Cantidad</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in productos)
                        {
                            <tr class="productRow" data-producto-id="@producto.Id" data-precio="@producto.Precio">
                                <td>
                                    <input type="hidden" name="VentasProductos.Index" value="@producto.Id" />
                                    <input type="hidden" name="VentasProductos[@producto.Id].ProductoId" value="@producto.Id" />
                                    <label>@producto.Nombre</label>
                                </td>
                                <td>
                                    <input type="text" name="VentasProductos[@producto.Id].Cantidad" class="form-control" pattern="[0-9]+(\.[0-9]+)?" title="cantidad" placeholder="0.0" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button type="submit" class="btn btn-primary">Aceptar</button>
        </form>
    </div>
    <div class="col-md-6">
        <!-- Lista de productos seleccionados -->
        <div class="form-group">
            <label style="font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif">Carrito:</label>
            <ul id="productosSeleccionados"></ul>

            <!-- Total del precio -->
            <div style="font-weight: bold; text-align: right; margin-top: 20px;">Total Precio: <span id="totalPrecioCarrito">$0.00</span></div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.StockAlert))
{
    <div class="alert alert-success">
        @ViewBag.StockAlert
    </div>
}

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    <script src="~/js/Venta.js"></script>
}




